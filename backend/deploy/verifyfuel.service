[Unit]
Description=VerifyFuel FastAPI backend
After=network.target

[Service]
User=ubuntu
Group=www-data
WorkingDirectory=/opt/verifyfuel/backend
EnvironmentFile=/opt/verifyfuel/backend/.env
ExecStart=/opt/verifyfuel/backend/venv/bin/uvicorn main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
